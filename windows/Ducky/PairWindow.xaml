<Window x:Class="Ducky.PairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="答鸭 Ducky — 绑定电脑"
        Width="360" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1b1b1f"
        ShowInTaskbar="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleHeader" Grid.Row="0" Text="绑定电脑" FontSize="20" FontWeight="SemiBold"
                   Foreground="#f0f0f3" HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock x:Name="SubtitleText" Grid.Row="1" Text="手机「答鸭」→ 绑定电脑 → 扫码或输入 6 位码"
                   FontSize="12" Foreground="#9a9aa2" TextWrapping="Wrap"
                   TextAlignment="Center" Margin="0,0,0,16"/>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="12"
                Width="240" Height="240" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image x:Name="QrImage" Stretch="Uniform"/>
        </Border>

        <TextBlock x:Name="CodeText" Grid.Row="3" Text="— — —" FontSize="34"
                   FontWeight="Bold" Foreground="#f0f0f3" FontFamily="Consolas"
                   HorizontalAlignment="Center" Margin="0,16,0,4"/>
        <TextBlock x:Name="HintText" Grid.Row="4" Text="正在获取配对码…"
                   FontSize="12" Foreground="#9a9aa2" HorizontalAlignment="Center"/>
    </Grid>
</Window>
